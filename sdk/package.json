{
  "name": "@rainbow-me/token-launcher",
  "version": "0.2.0",
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "eslint-config-rainbow": "4.3.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@ethersproject/bignumber": "5.7.0",
    "@ethersproject/contracts": "5.7.0",
    "@ethersproject/providers": "5.7.0",
    "@ethersproject/units": "5.7.0",
    "@ethersproject/wallet": "5.7.0",
    "clanker-sdk": "4.1.19",
    "jsbi": "^4.3.0",
    "tiny-invariant": "^1.3.3",
    "viem": "2.34.0"
  },
  "resolutions": {
    "viem": "2.34.0"
  },
  "author": "Christopher Howard",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "rm -rf dist",
    "build:clean": "yarn clean && yarn build",
    "prepublishOnly": "yarn build:clean",
    "prepare": "yarn build",
    "pretest": "grep -v '^IS_TESTING=' .env > .env.tmp 2>/dev/null || true; echo 'IS_TESTING=true' >> .env.tmp; mv .env.tmp .env",
    "test": "./scripts/test.sh",
    "lint": "eslint 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "format:check": "prettier --check '**/*.{js,ts,json,md}'",
    "format:fix": "prettier --write '**/*.{js,ts,json,md}'",
    "clean": "rm -rf dist"
  },
  "jest": {
    "moduleNameMapper": {
      "^clanker-sdk/dist/(.*)$": "<rootDir>/node_modules/clanker-sdk/dist/$1",
      "^clanker-sdk/v4$": "<rootDir>/node_modules/clanker-sdk/dist/v4/index.js"
    },
    "rootDir": ".",
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ],
      "^.+\\.(mjs|js)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!clanker-sdk|viem|@wagmi|abitype|@noble|@scure)/"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "mjs",
      "json"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/helpers/setupTestEnv.ts"
    ]
  },
  "sideEffects": false,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
