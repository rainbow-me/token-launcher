{
  "name": "@rainbow-me/token-launcher",
  "version": "0.1.0",
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^27.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@ethereumjs/util": "9.0.0",
    "@ethersproject/abi": "5.7.0",
    "@ethersproject/abstract-signer": "5.7.0",
    "@ethersproject/bignumber": "5.7.0",
    "@ethersproject/bytes": "5.7.0",
    "@ethersproject/contracts": "5.7.0",
    "@ethersproject/keccak256": "5.7.0",
    "@ethersproject/providers": "5.7.0",
    "@ethersproject/random": "5.7.0",
    "@ethersproject/solidity": "5.7.0",
    "@ethersproject/strings": "5.7.0",
    "@ethersproject/transactions": "5.7.0",
    "@ethersproject/units": "5.7.0",
    "@ethersproject/wallet": "5.7.0",
    "@metamask/eth-sig-util": "7.0.0",
    "clanker-sdk": "4.1.19",
    "decimal.js": "^10.5.0",
    "eslint-config-rainbow": "4.3.0",
    "jsbi": "^4.3.0",
    "prettier": "^3.3.3",
    "tiny-invariant": "^1.3.3",
    "viem": "2.34.0"
  },
  "resolutions": {
    "viem": "2.34.0"
  },
  "author": "Christopher Howard",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "rm -rf dist",
    "build:clean": "yarn clean && yarn build",
    "prepublishOnly": "yarn build:clean",
    "prepare": "yarn build",
    "pretest": "grep -v '^IS_TESTING=' .env > .env.tmp 2>/dev/null || true; echo 'IS_TESTING=true' >> .env.tmp; mv .env.tmp .env",
    "test": "./scripts/test.sh",
    "lint": "eslint 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "format:check": "prettier --check '**/*.{js,ts,json,md}'",
    "format:fix": "prettier --write '**/*.{js,ts,json,md}'",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "jest": {
    "moduleNameMapper": {
      "^clanker-sdk/dist/(.*)$": "<rootDir>/node_modules/clanker-sdk/dist/$1",
      "^clanker-sdk/v4$": "<rootDir>/node_modules/clanker-sdk/dist/v4/index.js"
    },
    "rootDir": ".",
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts", ".tsx"],
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", { "useESM": true, "tsconfig": "tsconfig.json" }],
      "^.+\\.(mjs|js)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!clanker-sdk|viem|@wagmi|abitype|@noble|@scure)/"
    ],
    "moduleFileExtensions": ["ts", "tsx", "js", "mjs", "json"],
    "setupFilesAfterEnv": [
      "<rootDir>/test/helpers/setupTestEnv.ts"
    ]
  },
  "sideEffects": false
}
