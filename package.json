{
  "name": "@rainbow-me/token-launcher",
  "version": "0.2.0",
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@changesets/cli": "^2.27.1",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "eslint-config-rainbow": "4.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@ethersproject/bignumber": "5.7.0",
    "@ethersproject/contracts": "5.7.0",
    "@ethersproject/providers": "5.7.0",
    "@ethersproject/units": "5.7.0",
    "@ethersproject/wallet": "5.7.0",
    "clanker-sdk": "4.1.19",
    "jsbi": "^4.3.0",
    "tiny-invariant": "^1.3.3",
    "tslib": "^2.6.0",
    "viem": "2.34.0"
  },
  "resolutions": {
    "viem": "2.34.0"
  },
  "author": "Christopher Howard",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prebuild": "rm -rf dist",
    "build:clean": "yarn clean && yarn build",
    "prepack": "yarn build:clean",
    "test": "./scripts/test.sh",
    "lint": "eslint 'src/**/*.{js,ts}' 'test/**/*.{js,ts}'",
    "format:check": "prettier --check '**/*.{js,ts,json,md}'",
    "format:fix": "prettier --write '**/*.{js,ts,json,md}'",
    "clean": "rm -rf dist",
    "changeset": "changeset",
    "release": "yarn release:verify-git && yarn release:publish && yarn release:github",
    "release:verify-git": "git diff --exit-code && git rev-parse --abbrev-ref HEAD | grep -q main",
    "release:publish": "yarn build && changeset publish --tag latest && git push --follow-tags",
    "release:github": "TAG=$(git describe --tags --abbrev=0) && awk '/^## /{if(p++)exit;next}p' CHANGELOG.md | gh release create \"$TAG\" --notes-file -"
  },
  "jest": {
    "moduleNameMapper": {
      "^clanker-sdk/dist/(.*)$": "<rootDir>/node_modules/clanker-sdk/dist/$1",
      "^clanker-sdk/v4$": "<rootDir>/node_modules/clanker-sdk/dist/v4/index.js"
    },
    "rootDir": ".",
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.json"
        }
      ],
      "^.+\\.(mjs|js)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!clanker-sdk|viem|@wagmi|abitype|@noble|@scure)/"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "mjs",
      "json"
    ]
  },
  "sideEffects": false,
  "packageManager": "yarn@4.2.2"
}
